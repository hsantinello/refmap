{
    "name": "refmap",
    "version": "0.0.15",
    "description": "Canvas flutuante de referÃªncias para criadores de IA",
    "main": "out/main/index.js",
    "author": "Ref Map",
    "repository": "https://github.com/hsantinello/refmap",
    "private": true,
    "scripts": {
        "dev": "electron-vite dev",
        "build": "electron-vite build",
        "preview": "electron-vite preview",
        "dist:win": "npm run build && electron-builder --win",
        "dist:win:publish": "electron-vite build && dotenv -e .env electron-builder --win --publish always",
        "dist:mac": "npm run build && electron-builder --mac",
        "gen-license": "tsx scripts/generate-license.ts",
        "postinstall": "electron-rebuild -f -w better-sqlite3"
    },
    "build": {
        "appId": "com.refmap.app",
        "productName": "Ref Map",
        "copyright": "Copyright © 2026",
        "compression": "normal",
        "directories": {
            "output": "dist",
            "buildResources": "build"
        },
        "files": [
            "out/**/*",
            "node_modules/**/*",
            "!node_modules/.cache",
            "!node_modules/**/*.md",
            "!node_modules/**/*.map",
            "!node_modules/**/test/**",
            "!node_modules/**/tests/**",
            "!node_modules/**/__tests__/**",
            "!node_modules/**/docs/**",
            "!node_modules/**/example/**",
            "!node_modules/**/examples/**",
            "!node_modules/**/.npmignore",
            "!node_modules/**/CHANGELOG*",
            "!node_modules/**/README*",
            "!node_modules/**/LICENSE*",
            "!node_modules/**/*.ts",
            "!node_modules/**/*.flow"
        ],
        "win": {
            "target": [
                {
                    "target": "nsis",
                    "arch": [
                        "x64"
                    ]
                }
            ],
            "icon": "build/icon.png"
        },
        "mac": {
            "target": [
                { "target": "dmg", "arch": ["universal"] }
            ],
            "icon": "build/icon.png",
            "category": "public.app-category.graphics-design",
            "hardenedRuntime": true,
            "gatekeeperAssess": false,
            "entitlements": "build/entitlements.mac.plist",
            "entitlementsInherit": "build/entitlements.mac.plist"
        },
        "dmg": {
            "title": "Ref Map",
            "window": { "width": 540, "height": 380 }
        },
        "nsis": {
            "oneClick": false,
            "allowToChangeInstallationDirectory": true,
            "createDesktopShortcut": true,
            "createStartMenuShortcut": true,
            "shortcutName": "Ref Map"
        },
        "publish": {
            "provider": "github",
            "owner": "hsantinello",
            "repo": "refmap",
            "releaseType": "release"
        }
    },
    "dependencies": {
        "@anthropic-ai/sdk": "^0.37.0",
        "@dnd-kit/core": "^6.3.1",
        "@dnd-kit/sortable": "^8.0.0",
        "@dnd-kit/utilities": "^3.2.2",
        "@supabase/supabase-js": "^2.106.1",
        "@xyflow/react": "^12.6.4",
        "better-sqlite3": "^11.9.1",
        "electron-updater": "^6.8.9",
        "exifr": "^7.1.3",
        "framer-motion": "^12.40.0",
        "openai": "^4.98.0",
        "pixi.js": "^8.18.1",
        "react": "^19.1.0",
        "react-dom": "^19.1.0",
        "sharp": "^0.34.2",
        "uuid": "^11.1.0",
        "zustand": "^5.0.3"
    },
    "devDependencies": {
        "@electron/rebuild": "^4.0.4",
        "@tailwindcss/vite": "^4.1.6",
        "@types/better-sqlite3": "^7.6.12",
        "@types/node": "^22.15.17",
        "@types/react": "^19.1.3",
        "@types/react-dom": "^19.1.3",
        "@types/uuid": "^10.0.0",
        "@vitejs/plugin-react": "^4.4.1",
        "dotenv-cli": "^11.0.0",
        "electron": "^36.2.1",
        "electron-builder": "^25.1.8",
        "electron-vite": "^3.1.0",
        "tailwindcss": "^4.1.6",
        "tsx": "^4.19.4",
        "typescript": "^5.8.3",
        "vite": "^6.3.5"
    }
}
